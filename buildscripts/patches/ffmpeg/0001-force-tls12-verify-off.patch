ffmpeg/tls_mbedtls: force TLS1.2 whenever certificate verification is off

mbedTLS 3.6.x (this tree ships 3.6.6) regressed disabling certificate
verification under TLSv1.3. Upstream only forces the TLS1.2 downgrade when the
mbedTLS runtime version equals exactly 3.6.0, so a 3.6.6 build keeps
negotiating TLS1.3 with verify=none and fails the handshake (mbedtls error
-0x6600) on direct-connect HTTPS streams. Drop the version pin so the
downgrade applies for every mbedTLS 3.6.x whenever verification is disabled.

diff --git a/libavformat/tls_mbedtls.c b/libavformat/tls_mbedtls.c
--- a/libavformat/tls_mbedtls.c
+++ b/libavformat/tls_mbedtls.c
@@ -610,9 +610,10 @@
     }
 
 #ifdef MBEDTLS_SSL_PROTO_TLS1_3
-    // this version does not allow disabling certificate verification with TLSv1.3 (yes, really).
-    if (mbedtls_version_get_number() == 0x03060000 && !shr->verify) {
+    // HmLanxi: mbedTLS 3.6.x regressed disabling cert verification under TLSv1.3;
+    // our default is verify=off, so force TLS 1.2 whenever verification is disabled.
+    if (!shr->verify) {
         av_log(h, AV_LOG_INFO, "Forcing TLSv1.2 because certificate verification is disabled\n");
         mbedtls_ssl_conf_max_tls_version(&tls_ctx->ssl_config, MBEDTLS_SSL_VERSION_TLS1_2);
     }
 #endif
